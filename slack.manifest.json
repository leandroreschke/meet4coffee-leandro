{
  "display_information": {
    "name": "Meet 4 Coffee"
  },
  "features": {
    "bot_user": {
      "display_name": "Meet 4 Coffee",
      "always_online": false
    }
  },
  "oauth_config": {
    "redirect_urls": [
      "http://localhost:3000/api/integrations/slack/callback"
    ],
    "scopes": {
      "bot": [
        "chat:write"
      ]
    }
  },
  "settings": {
    "interactivity": {
      "is_enabled": true,
      "request_url": "http://localhost:3000/api/slack/actions"
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": false,
    "token_rotation_enabled": false
  }
}
